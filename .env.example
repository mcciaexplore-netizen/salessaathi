# ─────────────────────────────────────────────────────────────────────────────
# SalesSaathi · Environment Configuration
#
# Copy this file to .env  (the installer does this automatically)
# The first-run wizard fills in most of these values for you.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-random-string

# Set to true after the first-run wizard completes
SETUP_DONE=false


# ── Database ──────────────────────────────────────────────────────────────────
# Options: sqlite | pocketbase

DB_TYPE=sqlite

# SQLite: path to the database file (relative to the project root)
SQLITE_PATH=./data/salessaathi.db

# PocketBase: URL and admin credentials
# (only needed if DB_TYPE=pocketbase)
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_EMAIL=
POCKETBASE_PASSWORD=


# ── AI Providers (optional — prefer adding keys via the Settings UI) ──────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=


# ── Email (optional — configure via Settings UI) ──────────────────────────────
# Options: Gmail SMTP, Brevo, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=


# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
